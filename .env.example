# Braveclon Environment Variables
# Copy this file to .env.local and fill in the values

# ==========================================
# Supabase Configuration (Optional)
# ==========================================
# The app runs in offline mode if these are not set.
# Get these from your Supabase project dashboard: Settings > API

# Public (client-safe) variables
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Private (server-only) - not needed for client auth
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ==========================================
# App Configuration
# ==========================================
# APP_URL: The Vercel deployment URL (auto-set by Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Google AI (Optional - for future AI features)
# ==========================================
# GEMINI_API_KEY="your-gemini-api-key"
